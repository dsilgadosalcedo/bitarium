{
  "name": "bitarium",
  "version": "0.2.0",
  "description": "A modern, collaborative drawing application built with Excalidraw, Next.js, and Convex",
  "license": "MIT",
  "keywords": [
    "drawing",
    "excalidraw",
    "collaboration",
    "nextjs",
    "convex",
    "real-time",
    "canvas",
    "whiteboard"
  ],
  "author": "David Silgado Salcedo <dsilgadosalcedo@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/dsilgadosalcedo/bitarium"
  },
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "npm-run-all2 --parallel dev:frontend dev:backend",
    "dev:frontend": "portless",
    "dev:frontend:app": "next dev",
    "dev:backend": "convex dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ignore-pattern \"convex/_generated/**\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test e2e-playwright",
    "analyze": "pnpm run build && pnpm exec next experimental-analyze",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/backend": "^3.6.1",
    "@clerk/nextjs": "^7.5.1",
    "@clerk/ui": "^1.17.0",
    "@excalidraw/excalidraw": "^0.18.1",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@radix-ui/react-visually-hidden": "^1.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.41.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@clerk/testing": "^2.1.1",
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "happy-dom": "^20.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "npm-run-all2": "^9.0.1",
    "portless": "^0.14.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "portless": {
    "name": "bitarium",
    "script": "dev:frontend:app"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --ignore-pattern \"convex/_generated/**\"",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
