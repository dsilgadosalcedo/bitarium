# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=

NEXT_PUBLIC_CONVEX_URL=

# Local dev URL (portless serves the app at https://bitarium.localhost)
NEXT_PUBLIC_SITE_URL=https://bitarium.localhost

# Shown on legal pages and privacy/terms contact sections
NEXT_PUBLIC_CONTACT_EMAIL=you@example.com

# Optional SEO overrides (defaults: 7Lineas / https://7lineas.com)
# NEXT_PUBLIC_PUBLISHER_NAME=7Lineas
# NEXT_PUBLIC_PUBLISHER_URL=https://7lineas.com

# Clerk (https://dashboard.clerk.com) — activate the Convex integration in Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_SECRET_KEY=
# Playwright E2E (@clerk/testing) reads CLERK_SECRET_KEY and maps
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY -> CLERK_PUBLISHABLE_KEY automatically.
# Clerk Frontend API URL, e.g. https://verb-noun-00.clerk.accounts.dev
# Set on Convex too:
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN ...
#   npx convex env set CLERK_SECRET_KEY ...
CLERK_JWT_ISSUER_DOMAIN=
